# --- Environment Setup ---
ENVIRONMENT=local # Set to 'production' in Google Cloud Run
PORT=8080

# --- Database ---
DATABASE_URL=postgresql+asyncpg://receipt_user:receipt_password@localhost:5432/receipt_db

# --- Third Party API Keys ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GMAIL_CLIENT_ID=your_gmail_client_googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# --- Google Cloud Config ---
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-receipts-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=./gcp-creds.json

# --- Firebase Frontend Integration ---
FIREBASE_PROJECT_ID=kelton-230
